---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - The Menon Lab">
  <article class="about-page">
    <h1>About The Menon Lab</h1>
    
    <section class="intro">
      <p>
        I'm <strong>Dr. Prahlad G. Menon</strong> — founder of 
        <a href="https://quantmd.com" target="_blank" class="link-quantmd">QuantMD</a> and 
        <a href="https://thinkcreate.ai" target="_blank" class="link-thinkcreate">ThinkCreate.AI</a>.
      </p>
      
      <p>
        With a PhD from Carnegie Mellon University, PMP certification, and NVIDIA GenAI LLMs credentials, 
        I bring deep expertise in artificial intelligence, machine learning, computer vision, and data science 
        to everything I build.
      </p>

      <p>
        This blog documents interesting projects, libraries, and tools I discover across the AI/ML ecosystem. 
        I find these while browsing GitHub, reading papers, and exploring what builders are creating.
      </p>
    </section>

    <section>
      <h2>What I Write About</h2>
      <ul>
        <li><strong>AI Agents</strong> — Autonomous systems, multi-agent frameworks, tool use</li>
        <li><strong>Large Language Models</strong> — New models, fine-tuning, deployment</li>
        <li><strong>Computer Vision</strong> — Medical imaging, video understanding, generation</li>
        <li><strong>Healthcare AI</strong> — Clinical applications, medical research tools</li>
        <li><strong>RAG Systems</strong> — Vector databases, retrieval, knowledge management</li>
        <li><strong>Open Source Tools</strong> — Libraries and projects worth knowing about</li>
      </ul>
    </section>

    <section>
      <h2>Connect</h2>
      <div class="connect-links">
        <a href="https://themenonlab.com" target="_blank" rel="noopener noreferrer">
          🌐 themenonlab.com
        </a>
        <a href="https://github.com/menonpg" target="_blank" rel="noopener noreferrer">
          💻 GitHub
        </a>
        <a href="https://twitter.com/themedcave" target="_blank" rel="noopener noreferrer">
          🐦 Twitter/X
        </a>
        <a href="https://linkedin.com/in/prahladmenon" target="_blank" rel="noopener noreferrer">
          💼 LinkedIn
        </a>
        <a href="/contact">
          ✉️ Contact
        </a>
      </div>
    </section>

    <section class="cta-section">
      <h2>Work With Me</h2>
      <div class="cta-cards">
        <a href="https://themenonlab.com/learn" target="_blank" rel="noopener noreferrer" class="cta-card">
          <span class="cta-icon">📚</span>
          <span class="cta-text">
            <strong>Learn AI</strong>
            <span>Courses and tutorials</span>
          </span>
        </a>
        <a href="https://thinkcreate.ai" target="_blank" rel="noopener noreferrer" class="cta-card">
          <span class="cta-icon">🤝</span>
          <span class="cta-text">
            <strong>AI Consulting</strong>
            <span>Build with experts</span>
          </span>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .about-page {
    max-width: 42rem;
    margin: 0 auto;
  }

  h1 {
    margin-bottom: 2rem;
  }

  section {
    margin-bottom: 2.5rem;
  }

  .intro {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  p {
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  h2 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  ul {
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
    color: var(--muted);
  }

  a {
    color: var(--accent);
  }

  .link-quantmd {
    color: #f97316;
    text-decoration: none;
    font-weight: 500;
  }

  .link-quantmd:hover {
    text-decoration: underline;
  }

  .link-thinkcreate {
    color: #14b8a6;
    text-decoration: none;
    font-weight: 500;
  }

  .link-thinkcreate:hover {
    text-decoration: underline;
  }

  /* Connect links */
  .connect-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .connect-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--fg);
    transition: background 0.2s, color 0.2s;
  }

  .connect-links a:hover {
    background: var(--accent);
    color: white;
  }

  /* CTA section */
  .cta-section {
    background: rgba(96, 165, 250, 0.05);
    padding: 2rem;
    border-radius: 1rem;
    margin-top: 1rem;
  }

  .cta-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .cta-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .cta-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.2s, transform 0.2s;
  }

  .cta-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .cta-icon {
    font-size: 1.5rem;
  }

  .cta-text {
    display: flex;
    flex-direction: column;
  }

  .cta-text strong {
    font-size: 1rem;
    color: var(--fg);
  }

  .cta-text span:last-child {
    font-size: 0.875rem;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .connect-links {
      flex-direction: column;
    }

    .connect-links a {
      width: 100%;
      justify-content: center;
    }
  }
</style>
