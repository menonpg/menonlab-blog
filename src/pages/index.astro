---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all posts
const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Featured collections - curated post groups
const collections = [
  {
    title: "Soul Ecosystem",
    emoji: "🧠",
    description: "Persistent memory, estate vaults, and enterprise AI — our open-source projects",
    slugs: [
      "soul-py-persistent-memory-llm-agents",
      "soul-legacy-digital-estate-vault",
      "introducing-soulmate-persistent-ai-memory-service",
      "soul-schema-auto-document-data-warehouse",
      "n8n-workflows-forget-everything-soul-stack"
    ],
    link: "/open-source"
  },
  {
    title: "Soul How-To Guides",
    emoji: "📚",
    description: "Tutorials, comparisons, and deep dives on using the Soul ecosystem",
    slugs: [
      "soul-py-v2-rag-rlm-hybrid",
      "meet-darwin-soul-book-ai-companion",
      "add-soul-any-repo-5-minutes",
      "soul-py-n8n-persistent-memory-workflows",
      "soul-py-vs-memu-agent-memory-compared",
      "soul-py-darwin-evolution-agent-identity"
    ],
    link: "/open-source"
  },
  {
    title: "Thought Leadership",
    emoji: "💡",
    description: "Original perspectives on where AI is heading",
    slugs: [
      "ai-capital-organizational-strategy",
      "human-ai-collaboration-radiology-rethinking",
      "code-vs-json-llm-tool-calling"
    ]
  },
  {
    title: "Research Deep Dives",
    emoji: "🔬",
    description: "Understanding the science behind the breakthroughs",
    slugs: [
      "small-models-big-performance-nature-paper",
      "grokking-777-parameter-transformer",
      "qwen-vl-multi-turn-visual-context",
      "pinns-pinos-mesh-free-simulation"
    ]
  },
  {
    title: "Practical Guides",
    emoji: "🛠️",
    description: "Hands-on tutorials that get you results",
    slugs: [
      "7-rag-patterns-2026",
      "mcp-database-wars-google-vs-mindsdb",
      "context-rot-ai-coding-agents",
      "local-voice-ai-complete-guide"
    ]
  },
  {
    title: "Security & Trust",
    emoji: "🔐",
    description: "Keeping AI systems safe and reliable",
    slugs: [
      "agents-md-security-risk-ai-agents",
      "crust-ai-agent-security-gateway",
      "claude-code-security-10-billion-wake-up-call"
    ]
  },
  {
    title: "Tools That Ship",
    emoji: "📦",
    description: "Open-source projects ready to use today",
    slugs: [
      "openclaw-open-source-ai-assistant",
      "ai-agents-android-droidclaw-openclaw-termux",
      "browser-use-ai-browser-automation",
      "unsloth-fast-llm-finetuning"
    ]
  }
];

// Resolve slugs to actual posts
const resolvedCollections = collections.map(col => ({
  ...col,
  posts: col.slugs
    .map(slug => allPosts.find(p => p.slug === slug))
    .filter(Boolean)
}));

// Recent posts (excluding featured ones)
const featuredSlugs = new Set(collections.flatMap(c => c.slugs));
const recentPosts = allPosts
  .filter(p => !featuredSlugs.has(p.slug))
  .slice(0, 5);
---

<BaseLayout title="The Menon Lab - AI & Open Source Insights" includeWebSiteSchema={true}>
  <div class="hero">
    <div class="hero-content">
      <h1>The Menon Lab</h1>
      <p class="subtitle">
        Curated insights on AI, machine learning, and open-source tools — by Dr. Prahlad G. Menon
      </p>
      <a href="/blog" class="button-primary">Browse All Posts →</a>
    </div>
  </div>

  <section class="featured-collections">
    <h2>Featured Collections</h2>
    <div class="collections-grid">
      {resolvedCollections.map((collection) => (
        <div class="collection-card">
          <div class="collection-header">
            <span class="collection-emoji">{collection.emoji}</span>
            <h3>{collection.title}</h3>
          </div>
          <p class="collection-description">{collection.description}</p>
          <ul class="collection-posts">
            {collection.posts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </li>
            ))}
          </ul>
          {collection.link && (
            <a href={collection.link} class="collection-link">View all →</a>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="latest-posts">
    <h2>Latest Posts</h2>
    <div class="posts-grid">
      {recentPosts.map((post) => (
        <article class="post-card">
          <a href={`/blog/${post.slug}/`}>
            <h3>{post.data.title}</h3>
            <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            {post.data.tags && (
              <div class="tags">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))}
    </div>
    <a href="/blog" class="view-all">View all posts →</a>
  </section>

  <section class="about">
    <h2>About</h2>
    <p>
      I'm a researcher and engineer exploring the intersection of AI, healthcare, and practical tooling.
      This blog documents interesting projects, libraries, and tools I discover across the AI/ML ecosystem.
    </p>
    <p>
      Topics include: AI agents, large language models, computer vision, healthcare AI, RAG systems, 
      and open-source tools worth knowing about.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--fg) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--muted);
    margin-bottom: 2rem;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }

  .button-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
    color: white;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .button-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(96, 165, 250, 0.3);
  }

  /* Featured Collections */
  .featured-collections {
    margin-bottom: 4rem;
  }

  .featured-collections h2 {
    margin-bottom: 1.5rem;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .collections-grid {
      grid-template-columns: 1fr;
    }
  }

  .collection-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--bg);
    transition: all 0.2s;
  }

  .collection-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(96, 165, 250, 0.1);
  }

  .collection-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .collection-emoji {
    font-size: 1.5rem;
  }

  .collection-header h3 {
    font-size: 1.1rem;
    margin: 0;
  }

  .collection-description {
    font-size: 0.875rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .collection-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .collection-posts li {
    padding-left: 1rem;
    position: relative;
  }

  .collection-posts li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .collection-posts a {
    color: var(--fg);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .collection-posts a:hover {
    color: var(--accent);
  }

  .collection-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .collection-link:hover {
    text-decoration: underline;
  }

  /* Latest Posts */
  .latest-posts {
    margin-bottom: 4rem;
  }

  .latest-posts h2 {
    margin-bottom: 2rem;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    transition: all 0.2s;
  }

  .post-card:hover {
    border-color: var(--accent);
    transform: translateX(4px);
  }

  .post-card a {
    text-decoration: none;
    color: inherit;
  }

  .post-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .post-card time {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: rgba(96, 165, 250, 0.1);
    color: var(--accent);
    border-radius: 0.25rem;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.5rem;
    color: var(--accent);
    font-weight: 500;
  }

  /* About */
  .about {
    padding: 2rem;
    background: rgba(96, 165, 250, 0.05);
    border-radius: 1rem;
    margin-bottom: 2rem;
  }

  .about h2 {
    margin-bottom: 1rem;
  }

  .about p {
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .subtitle {
      font-size: 1rem;
    }
  }
</style>
