---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Analytics Dashboard | The Menon Lab" description="Traffic insights and analytics for The Menon Lab">
  <div class="analytics-hero">
    <div class="hero-content">
      <h1>📊 Analytics Dashboard</h1>
      <p class="subtitle">Traffic insights for The Menon Lab</p>
    </div>
    <div class="hero-controls">
      <div class="filter-group">
        <label>Date Range</label>
        <div class="pill-group" id="dateRange">
          <button class="pill" data-days="7">7 days</button>
          <button class="pill active" data-days="14">14 days</button>
          <button class="pill" data-days="30">30 days</button>
          <button class="pill" data-days="90">90 days</button>
        </div>
      </div>
      <!-- Site filter disabled - Cloudflare API doesn't support hostname breakdown for this zone -->
      <!--
      <div class="filter-group">
        <label>Site</label>
        <div class="pill-group" id="siteFilter">
          <button class="pill active" data-host="all">All Sites</button>
          <button class="pill" data-host="themenonlab.com">Main Site</button>
          <button class="pill" data-host="blog.themenonlab.com">Blog</button>
        </div>
      </div>
      -->
      <button class="button-primary" id="refreshBtn">
        <span class="btn-icon">↻</span> Refresh
      </button>
    </div>
  </div>

  <div class="meta-bar">
    <span id="lastUpdated">Loading...</span>
    <!-- Compare toggle disabled - needs hostname data -->
    <!--
    <label class="compare-toggle">
      <input type="checkbox" id="compareMode" />
      <span>Compare sites on charts</span>
    </label>
    -->
  </div>

  <div id="content">
    <div class="loading-state">
      <div class="spinner"></div>
      <span>Loading analytics...</span>
    </div>
  </div>

  <aside class="chat-panel" id="chatPanel">
    <button class="chat-toggle" id="chatToggle" aria-label="Toggle chat">
      <span class="chat-icon">💬</span>
      <span class="chat-label">Ask Monica</span>
    </button>
    <div class="chat-container" id="chatContainer">
      <div class="chat-header">
        <div class="chat-title">
          <span class="chat-avatar">🦉</span>
          <div>
            <h3>Ask Monica</h3>
            <p>AI-powered analytics insights</p>
          </div>
        </div>
        <button class="chat-close" id="chatClose" aria-label="Close chat">×</button>
      </div>
      <div class="chat-messages" id="chatMessages">
        <div class="message assistant">
          <div class="message-content">
            Hi! I can help you understand your analytics. Ask me about traffic trends, compare sites, or anything about your data.
          </div>
        </div>
      </div>
      <div class="chat-input-area">
        <div class="suggested-prompts">
          <button class="prompt-chip" onclick="askPrompt(this)">Compare sites</button>
          <button class="prompt-chip" onclick="askPrompt(this)">Traffic trend?</button>
          <button class="prompt-chip" onclick="askPrompt(this)">Best day?</button>
        </div>
        <div class="chat-input-row">
          <input type="text" class="chat-input" id="chatInput" placeholder="Ask about your analytics..." onkeypress="if(event.key==='Enter')sendChat()" />
          <button class="chat-send" id="chatSend" onclick="sendChat()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </aside>
</BaseLayout>

<style>
  /* Hero & Controls */
  .analytics-hero {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }

  .analytics-hero h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
    background: linear-gradient(135deg, var(--fg) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle { color: var(--muted); font-size: 1rem; margin: 0; }

  .hero-controls {
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-group label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .pill-group {
    display: flex;
    background: var(--border);
    border-radius: 0.5rem;
    padding: 0.25rem;
    gap: 0.25rem;
  }

  .pill {
    padding: 0.5rem 0.75rem;
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .pill:hover { color: var(--fg); }
  .pill.active {
    background: var(--accent);
    color: white;
  }

  .button-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .button-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(96, 165, 250, 0.3);
  }

  .button-primary:disabled { opacity: 0.6; transform: none; }

  .meta-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .compare-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .compare-toggle input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--accent);
  }

  /* Loading */
  .loading-state {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 4rem;
    color: var(--muted);
  }

  .spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Stats */
  :global(.stats-grid) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  :global(.stat-card) {
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    transition: all 0.2s;
  }

  :global(.stat-card:hover) {
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(96, 165, 250, 0.1);
  }

  :global(.stat-card .label) {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  :global(.stat-card .value) {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--fg);
    line-height: 1.2;
  }

  :global(.stat-card .change) {
    font-size: 0.75rem;
    margin-top: 0.5rem;
  }

  :global(.stat-card .change.up) { color: #10b981; }
  :global(.stat-card .change.down) { color: #ef4444; }
  :global(.stat-card .change.neutral) { color: var(--muted); }

  /* Charts */
  :global(.charts-section) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  :global(.chart-card) {
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
  }

  :global(.chart-card.full-width) {
    grid-column: 1 / -1;
  }

  :global(.chart-card h3) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 1rem 0;
  }

  :global(.chart-container) {
    position: relative;
    height: 260px;
  }

  /* Insights */
  :global(.insights-card) {
    padding: 1.25rem;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.05) 0%, rgba(59, 130, 246, 0.02) 100%);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
  }

  :global(.insights-card h3) {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
  }

  :global(.insight-item) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  :global(.insight-item:last-child) { border-bottom: none; padding-bottom: 0; }
  :global(.insight-item:first-child) { padding-top: 0; }
  :global(.insight-icon) { font-size: 1.25rem; }
  :global(.insight-text) { font-size: 0.875rem; color: var(--muted); margin: 0; }
  :global(.insight-text strong) { color: var(--fg); }

  /* Table */
  :global(.table-card) {
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
  }

  :global(.table-card h3) {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
  }

  :global(.table-wrap) { overflow-x: auto; }
  :global(.data-table) { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  :global(.data-table th, .data-table td) { padding: 0.75rem; text-align: left; }
  :global(.data-table th) {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
  }
  :global(.data-table td) { border-bottom: 1px solid var(--border); }
  :global(.data-table tr:last-child td) { border-bottom: none; }
  :global(.data-table tr:hover td) { background: rgba(96, 165, 250, 0.03); }

  :global(.badge) {
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-left: 0.5rem;
  }
  :global(.badge.peak) { background: rgba(16, 185, 129, 0.15); color: #10b981; }
  :global(.badge.low) { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
  :global(.badge.main) { background: rgba(168, 85, 247, 0.15); color: #a855f7; }
  :global(.badge.blog) { background: rgba(96, 165, 250, 0.15); color: #60a5fa; }

  /* Chat Panel */
  .chat-panel { position: fixed; bottom: 2rem; right: 2rem; z-index: 50; }

  .chat-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
    color: white;
    border: none;
    border-radius: 2rem;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(96, 165, 250, 0.4);
    transition: all 0.2s;
  }

  .chat-toggle:hover { transform: translateY(-2px); }
  .chat-toggle.hidden { display: none; }

  .chat-container {
    display: none;
    flex-direction: column;
    width: 360px;
    height: 480px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    overflow: hidden;
  }

  .chat-container.active { display: flex; }

  .chat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.1) 0%, transparent 100%);
  }

  .chat-title { display: flex; align-items: center; gap: 0.75rem; }
  .chat-avatar { font-size: 1.5rem; }
  .chat-title h3 { font-size: 1rem; font-weight: 600; margin: 0; }
  .chat-title p { font-size: 0.7rem; color: var(--muted); margin: 0; }
  .chat-close { background: none; border: none; color: var(--muted); font-size: 1.5rem; cursor: pointer; }
  .chat-close:hover { color: var(--fg); }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .message { max-width: 85%; }
  .message.user { align-self: flex-end; }
  .message.assistant { align-self: flex-start; }

  .message-content {
    padding: 0.75rem 1rem;
    border-radius: 1rem;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .message.user .message-content {
    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
    color: white;
    border-bottom-right-radius: 0.25rem;
  }

  .message.assistant .message-content {
    background: var(--border);
    color: var(--fg);
    border-bottom-left-radius: 0.25rem;
  }

  .chat-input-area { padding: 1rem; border-top: 1px solid var(--border); }
  .suggested-prompts { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem; }

  .prompt-chip {
    background: var(--border);
    border: 1px solid transparent;
    border-radius: 1rem;
    padding: 0.35rem 0.65rem;
    font-size: 0.7rem;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
  }
  .prompt-chip:hover { border-color: var(--accent); color: var(--accent); }

  .chat-input-row { display: flex; gap: 0.5rem; }

  .chat-input {
    flex: 1;
    background: var(--border);
    border: 1px solid transparent;
    border-radius: 0.5rem;
    padding: 0.75rem;
    color: var(--fg);
    font-size: 0.85rem;
    outline: none;
  }
  .chat-input:focus { border-color: var(--accent); }
  .chat-input::placeholder { color: var(--muted); }

  .chat-send {
    width: 42px;
    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
    border: none;
    border-radius: 0.5rem;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    :global(.stats-grid) { grid-template-columns: repeat(2, 1fr); }
    :global(.charts-section) { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .analytics-hero { flex-direction: column; }
    .hero-controls { width: 100%; justify-content: flex-start; }
    :global(.stats-grid) { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    :global(.stat-card .value) { font-size: 1.5rem; }
    .chat-panel { bottom: 1rem; right: 1rem; }
    .chat-container { width: calc(100vw - 2rem); }
    .chat-label { display: none; }
  }
</style>

<script is:inline>
  // Load Chart.js dynamically
  function loadChartJS() {
    return new Promise((resolve, reject) => {
      if (typeof Chart !== 'undefined') {
        resolve();
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js';
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  const WORKER_URL = 'https://blog-analytics.prahlad-menon.workers.dev/';
  const CHAT_API_URL = '/api/chat';
  
  let rawData = null;
  let aggregateData = null;
  let byHostData = null;
  let totals = null;
  let currentDays = 14;
  let currentHost = 'all';
  let compareMode = false;

  // Utility functions
  function formatBytes(bytes) {
    if (bytes >= 1073741824) return (bytes / 1073741824).toFixed(2) + ' GB';
    if (bytes >= 1048576) return (bytes / 1048576).toFixed(1) + ' MB';
    return (bytes / 1024).toFixed(1) + ' KB';
  }

  function formatNumber(num) {
    if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
    if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
    return num.toLocaleString();
  }

  function formatDate(dateStr) {
    return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', { 
      weekday: 'short', month: 'short', day: 'numeric' 
    });
  }

  function getShortDate(dateStr) {
    return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  // Filter controls
  document.querySelectorAll('#dateRange .pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#dateRange .pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentDays = parseInt(btn.dataset.days);
      fetchAnalytics();
    });
  });

  document.querySelectorAll('#siteFilter .pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#siteFilter .pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentHost = btn.dataset.host;
      processData();
    });
  });

  document.getElementById('compareMode')?.addEventListener('change', (e) => {
    compareMode = e.target.checked;
    processData();
  });

  document.getElementById('refreshBtn')?.addEventListener('click', fetchAnalytics);

  // Chat toggle
  document.getElementById('chatToggle')?.addEventListener('click', () => {
    document.getElementById('chatToggle').classList.add('hidden');
    document.getElementById('chatContainer').classList.add('active');
  });

  document.getElementById('chatClose')?.addEventListener('click', () => {
    document.getElementById('chatContainer').classList.remove('active');
    document.getElementById('chatToggle').classList.remove('hidden');
  });

  async function fetchAnalytics() {
    const content = document.getElementById('content');
    const btn = document.getElementById('refreshBtn');
    
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner" style="width:14px;height:14px;display:inline-block"></span>';

    try {
      const response = await fetch(`${WORKER_URL}?days=${currentDays}`);
      rawData = await response.json();
      
      console.log('Worker response:', rawData);
      
      if (rawData.errors) throw new Error(rawData.errors[0].message);
      if (rawData.error) throw new Error(rawData.error);

      processData();
      document.getElementById('lastUpdated').textContent = `Updated ${new Date().toLocaleTimeString()}`;
    } catch (error) {
      console.error('Analytics error:', error);
      content.innerHTML = `<div class="loading-state" style="color:#ef4444">⚠️ ${error.message}</div>`;
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<span class="btn-icon">↻</span> Refresh';
    }
  }

  function processData() {
    if (!rawData?.data?.viewer?.zones?.[0]) {
      console.error('No zone data:', rawData);
      document.getElementById('content').innerHTML = '<div class="loading-state" style="color:#ef4444">⚠️ No data returned from Cloudflare</div>';
      return;
    }
    
    const zone = rawData.data.viewer.zones[0];
    console.log('Zone data:', zone);
    
    // Support both old Worker (httpRequests1dGroups) and new Worker (aggregate + byHost)
    byHostData = zone.byHost || [];
    aggregateData = zone.aggregate || zone.httpRequests1dGroups || [];
    
    console.log('Aggregate data:', aggregateData.length, 'items');
    console.log('ByHost data:', byHostData.length, 'items');
    
    // If we have byHost data and a specific filter, use it
    if (byHostData.length > 0 && currentHost !== 'all') {
      const hostData = byHostData.filter(d => d.dimensions.clientRequestHTTPHost === currentHost);
      aggregateData = aggregateByDate(hostData);
    }

    // Calculate totals
    totals = aggregateData.reduce((acc, day) => ({
      visitors: acc.visitors + day.uniq.uniques,
      pageViews: acc.pageViews + day.sum.pageViews,
      requests: acc.requests + day.sum.requests,
      bandwidth: acc.bandwidth + day.sum.bytes,
      threats: acc.threats + day.sum.threats,
      cached: acc.cached + (day.sum.cachedBytes || 0)
    }), { visitors: 0, pageViews: 0, requests: 0, bandwidth: 0, threats: 0, cached: 0 });

    renderDashboard();
  }

  function aggregateByDate(hostData) {
    const byDate = {};
    hostData.forEach(d => {
      const date = d.dimensions.date;
      if (!byDate[date]) {
        byDate[date] = { dimensions: { date }, sum: { requests: 0, pageViews: 0, bytes: 0, cachedBytes: 0, threats: 0 }, uniq: { uniques: 0 } };
      }
      byDate[date].sum.requests += d.sum.requests;
      byDate[date].sum.pageViews += d.sum.pageViews;
      byDate[date].sum.bytes += d.sum.bytes;
      byDate[date].sum.cachedBytes += d.sum.cachedBytes || 0;
      byDate[date].sum.threats += d.sum.threats;
      byDate[date].uniq.uniques += d.uniq.uniques;
    });
    return Object.values(byDate).sort((a, b) => a.dimensions.date.localeCompare(b.dimensions.date));
  }

  function getHostDataByDate(host) {
    const data = byHostData.filter(d => d.dimensions.clientRequestHTTPHost === host);
    return aggregateByDate(data);
  }

  function generateInsights() {
    const insights = [];
    const peakDay = [...aggregateData].sort((a, b) => b.sum.pageViews - a.sum.pageViews)[0];
    const avgViews = totals.pageViews / aggregateData.length;
    
    const third = Math.floor(aggregateData.length / 3);
    const recent = aggregateData.slice(-third);
    const older = aggregateData.slice(0, third);
    const recentAvg = recent.reduce((s, d) => s + d.sum.pageViews, 0) / recent.length;
    const olderAvg = older.reduce((s, d) => s + d.sum.pageViews, 0) / older.length;
    const trendPct = olderAvg ? ((recentAvg - olderAvg) / olderAvg * 100).toFixed(0) : 0;
    
    if (trendPct > 10) {
      insights.push({ icon: '📈', text: `Traffic is <strong>up ${trendPct}%</strong> compared to earlier in this period.` });
    } else if (trendPct < -10) {
      insights.push({ icon: '📉', text: `Traffic is <strong>down ${Math.abs(trendPct)}%</strong>. Consider promoting content.` });
    } else {
      insights.push({ icon: '➡️', text: `Traffic is <strong>stable</strong> with consistent engagement.` });
    }
    
    insights.push({ icon: '🏆', text: `<strong>${formatDate(peakDay.dimensions.date)}</strong> was peak with <strong>${formatNumber(peakDay.sum.pageViews)}</strong> views.` });
    
    // Only show site comparison if byHost data is available
    if (currentHost === 'all' && byHostData && byHostData.length > 0) {
      try {
        const mainTotal = byHostData.filter(d => d.dimensions?.clientRequestHTTPHost === 'themenonlab.com').reduce((s, d) => s + (d.sum?.pageViews || 0), 0);
        const blogTotal = byHostData.filter(d => d.dimensions?.clientRequestHTTPHost === 'blog.themenonlab.com').reduce((s, d) => s + (d.sum?.pageViews || 0), 0);
        const total = mainTotal + blogTotal;
        if (total > 0) {
          const blogPct = ((blogTotal / total) * 100).toFixed(0);
          insights.push({ icon: '📊', text: `Blog accounts for <strong>${blogPct}%</strong> of total traffic.` });
        }
      } catch (e) { /* byHost data not in expected format */ }
    }
    
    if (totals.threats > 0) {
      insights.push({ icon: '🛡️', text: `Blocked <strong>${totals.threats} threats</strong> — site protected.` });
    }
    
    return insights;
  }

  function renderDashboard() {
    const avgVisitors = Math.round(totals.visitors / aggregateData.length);
    const peakDay = [...aggregateData].sort((a, b) => b.sum.pageViews - a.sum.pageViews)[0];
    const lowDay = [...aggregateData].sort((a, b) => a.sum.pageViews - b.sum.pageViews)[0];
    const insights = generateInsights();

    document.getElementById('content').innerHTML = `
      <div class="stats-grid">
        <div class="stat-card">
          <div class="label">Visitors</div>
          <div class="value">${formatNumber(totals.visitors)}</div>
          <div class="change neutral">${avgVisitors}/day avg</div>
        </div>
        <div class="stat-card">
          <div class="label">Page Views</div>
          <div class="value">${formatNumber(totals.pageViews)}</div>
          <div class="change neutral">${Math.round(totals.pageViews / aggregateData.length)}/day</div>
        </div>
        <div class="stat-card">
          <div class="label">Bandwidth</div>
          <div class="value">${formatBytes(totals.bandwidth)}</div>
          <div class="change neutral">${formatBytes(totals.bandwidth / aggregateData.length)}/day</div>
        </div>
        <div class="stat-card">
          <div class="label">Peak Day</div>
          <div class="value">${formatNumber(peakDay.sum.pageViews)}</div>
          <div class="change up">${formatDate(peakDay.dimensions.date)}</div>
        </div>
      </div>

      <div class="charts-section">
        <div class="chart-card ${compareMode ? 'full-width' : ''}">
          <h3>${compareMode ? '📈 Page Views by Site' : '📈 Page Views'}</h3>
          <div class="chart-container"><canvas id="trafficChart"></canvas></div>
        </div>
        ${!compareMode ? `
        <div class="chart-card">
          <h3>📊 Daily Visitors</h3>
          <div class="chart-container"><canvas id="visitorsChart"></canvas></div>
        </div>
        ` : `
        <div class="chart-card full-width">
          <h3>👥 Visitors by Site</h3>
          <div class="chart-container"><canvas id="visitorsChart"></canvas></div>
        </div>
        `}
      </div>

      <div class="insights-card">
        <h3>💡 Insights</h3>
        ${insights.map(i => `
          <div class="insight-item">
            <span class="insight-icon">${i.icon}</span>
            <p class="insight-text">${i.text}</p>
          </div>
        `).join('')}
      </div>

      <div class="table-card">
        <h3>📋 Daily Breakdown</h3>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Visitors</th>
                <th>Page Views</th>
                <th>Requests</th>
                <th>Bandwidth</th>
              </tr>
            </thead>
            <tbody>
              ${[...aggregateData].reverse().slice(0, 14).map(day => `
                <tr>
                  <td>
                    ${formatDate(day.dimensions.date)}
                    ${day === peakDay ? '<span class="badge peak">Peak</span>' : ''}
                    ${day === lowDay ? '<span class="badge low">Low</span>' : ''}
                  </td>
                  <td>${formatNumber(day.uniq.uniques)}</td>
                  <td><strong>${formatNumber(day.sum.pageViews)}</strong></td>
                  <td>${formatNumber(day.sum.requests)}</td>
                  <td>${formatBytes(day.sum.bytes)}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      </div>
    `;
    
    renderCharts();
  }

  function renderCharts() {
    const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
    const gridColor = isDark ? '#262626' : '#e5e5e5';
    const textColor = isDark ? '#a3a3a3' : '#525252';
    
    // Only use compare mode if we have byHost data
    if (compareMode && byHostData && byHostData.length > 0) {
      renderComparisonCharts(gridColor, textColor);
    } else {
      renderSingleCharts(gridColor, textColor);
    }
  }

  function renderSingleCharts(gridColor, textColor) {
    const labels = aggregateData.map(d => getShortDate(d.dimensions.date));
    const pageViews = aggregateData.map(d => d.sum.pageViews);
    const visitors = aggregateData.map(d => d.uniq.uniques);
    const maxVisitors = Math.max(...visitors);

    new Chart(document.getElementById('trafficChart'), {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Page Views',
          data: pageViews,
          borderColor: '#60a5fa',
          backgroundColor: 'rgba(96, 165, 250, 0.1)',
          fill: true,
          tension: 0.4,
          pointRadius: 3,
          pointHoverRadius: 5
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: textColor, maxRotation: 45 } },
          y: { grid: { color: gridColor }, ticks: { color: textColor } }
        }
      }
    });

    new Chart(document.getElementById('visitorsChart'), {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          data: visitors,
          backgroundColor: visitors.map(v => v === maxVisitors ? '#10b981' : 'rgba(96, 165, 250, 0.6)'),
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { color: textColor, maxRotation: 45 } },
          y: { grid: { color: gridColor }, ticks: { color: textColor } }
        }
      }
    });
  }

  function renderComparisonCharts(gridColor, textColor) {
    const mainData = getHostDataByDate('themenonlab.com');
    const blogData = getHostDataByDate('blog.themenonlab.com');
    
    const allDates = [...new Set([...mainData.map(d => d.dimensions.date), ...blogData.map(d => d.dimensions.date)])].sort();
    const labels = allDates.map(d => getShortDate(d));
    
    const mainViews = allDates.map(date => mainData.find(d => d.dimensions.date === date)?.sum.pageViews || 0);
    const blogViews = allDates.map(date => blogData.find(d => d.dimensions.date === date)?.sum.pageViews || 0);
    const mainVisitors = allDates.map(date => mainData.find(d => d.dimensions.date === date)?.uniq.uniques || 0);
    const blogVisitors = allDates.map(date => blogData.find(d => d.dimensions.date === date)?.uniq.uniques || 0);

    new Chart(document.getElementById('trafficChart'), {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Main Site',
          data: mainViews,
          borderColor: '#a855f7',
          backgroundColor: 'rgba(168, 85, 247, 0.1)',
          fill: true,
          tension: 0.4,
          pointRadius: 3
        }, {
          label: 'Blog',
          data: blogViews,
          borderColor: '#60a5fa',
          backgroundColor: 'rgba(96, 165, 250, 0.1)',
          fill: true,
          tension: 0.4,
          pointRadius: 3
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { color: textColor, usePointStyle: true } } },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: textColor, maxRotation: 45 } },
          y: { grid: { color: gridColor }, ticks: { color: textColor } }
        }
      }
    });

    new Chart(document.getElementById('visitorsChart'), {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Main Site',
          data: mainVisitors,
          backgroundColor: 'rgba(168, 85, 247, 0.7)',
          borderRadius: 4
        }, {
          label: 'Blog',
          data: blogVisitors,
          backgroundColor: 'rgba(96, 165, 250, 0.7)',
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { color: textColor, usePointStyle: true } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: textColor, maxRotation: 45 } },
          y: { grid: { color: gridColor }, ticks: { color: textColor } }
        }
      }
    });
  }

  // Chat
  function askPrompt(el) {
    document.getElementById('chatInput').value = el.textContent;
    sendChat();
  }

  async function sendChat() {
    const input = document.getElementById('chatInput');
    const messages = document.getElementById('chatMessages');
    const question = input.value.trim();
    if (!question || !aggregateData) return;

    messages.innerHTML += `<div class="message user"><div class="message-content">${escapeHtml(question)}</div></div>`;
    input.value = '';
    messages.scrollTop = messages.scrollHeight;

    const typingId = 'typing-' + Date.now();
    messages.innerHTML += `<div class="message assistant" id="${typingId}"><div class="message-content">Thinking...</div></div>`;
    messages.scrollTop = messages.scrollHeight;

    let response;
    try {
      const gptResult = await fetchGPTResponse(question);
      if (gptResult && !gptResult.startsWith('Chat is currently unavailable')) {
        response = gptResult;
      } else {
        response = generateLocalResponse(question);
      }
    } catch (e) {
      response = generateLocalResponse(question);
    }

    document.getElementById(typingId).innerHTML = `<div class="message-content">${renderMarkdown(response)}</div>`;
    messages.scrollTop = messages.scrollHeight;
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderMarkdown(text) {
    if (!text) return '';
    return text
      // Code blocks
      .replace(/```[\s\S]*?```/g, m => `<pre><code>${m.slice(3, -3).trim()}</code></pre>`)
      // Inline code
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      // Bold
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/__([^_]+)__/g, '<strong>$1</strong>')
      // Italic
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(/_([^_]+)_/g, '<em>$1</em>')
      // Line breaks
      .replace(/\n/g, '<br>');
  }

  async function fetchGPTResponse(question) {
    const mainData = getHostDataByDate('themenonlab.com');
    const blogData = getHostDataByDate('blog.themenonlab.com');
    
    const context = `Analytics for ${currentDays} days (filter: ${currentHost}):
Total: ${totals.visitors} visitors, ${totals.pageViews} page views, ${formatBytes(totals.bandwidth)}
Main site total: ${mainData.reduce((s,d) => s + d.sum.pageViews, 0)} views
Blog total: ${blogData.reduce((s,d) => s + d.sum.pageViews, 0)} views
Daily: ${aggregateData.slice(-7).map(d => `${d.dimensions.date}: ${d.sum.pageViews} views`).join('; ')}`;

    const res = await fetch(CHAT_API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ question, context })
    });
    
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    return data.answer;
  }

  function generateLocalResponse(question) {
    const q = question.toLowerCase();
    const peakDay = [...aggregateData].sort((a, b) => b.sum.pageViews - a.sum.pageViews)[0];
    const avgViews = Math.round(totals.pageViews / aggregateData.length);

    if (q.includes('compare') || q.includes('site')) {
      const mainTotal = byHostData.filter(d => d.dimensions.clientRequestHTTPHost === 'themenonlab.com').reduce((s, d) => s + d.sum.pageViews, 0);
      const blogTotal = byHostData.filter(d => d.dimensions.clientRequestHTTPHost === 'blog.themenonlab.com').reduce((s, d) => s + d.sum.pageViews, 0);
      return `<strong>Main site:</strong> ${formatNumber(mainTotal)} views<br><strong>Blog:</strong> ${formatNumber(blogTotal)} views<br>Blog is ${((blogTotal/(mainTotal+blogTotal))*100).toFixed(0)}% of total traffic.`;
    }

    if (q.includes('best') || q.includes('peak') || q.includes('top')) {
      return `Peak was <strong>${formatDate(peakDay.dimensions.date)}</strong> with ${formatNumber(peakDay.sum.pageViews)} views — ${Math.round(peakDay.sum.pageViews / avgViews * 100 - 100)}% above average.`;
    }

    if (q.includes('trend')) {
      const third = Math.floor(aggregateData.length / 3);
      const recent = aggregateData.slice(-third);
      const older = aggregateData.slice(0, third);
      const recentAvg = recent.reduce((s, d) => s + d.sum.pageViews, 0) / recent.length;
      const olderAvg = older.reduce((s, d) => s + d.sum.pageViews, 0) / older.length;
      const pct = ((recentAvg - olderAvg) / olderAvg * 100).toFixed(0);
      return pct > 0 ? `📈 Up <strong>${pct}%</strong> recently!` : `📉 Down <strong>${Math.abs(pct)}%</strong> recently.`;
    }

    return `${currentDays} days: <strong>${formatNumber(totals.pageViews)}</strong> views, <strong>${formatNumber(totals.visitors)}</strong> visitors. Peak: ${formatDate(peakDay.dimensions.date)}.`;
  }

  // Initialize: load Chart.js first, then fetch analytics
  loadChartJS()
    .then(() => fetchAnalytics())
    .catch(err => {
      console.error('Failed to load Chart.js:', err);
      document.getElementById('content').innerHTML = '<div class="loading-state" style="color:#ef4444">⚠️ Failed to load charting library</div>';
    });
</script>
