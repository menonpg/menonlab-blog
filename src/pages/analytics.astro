---
// Hidden analytics page - not linked anywhere
// Access at: /analytics
// Uses Cloudflare Worker for live data
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Analytics | The Menon Lab</title>
  <style>
    :root {
      --bg: #0a0a0a;
      --card-bg: #141414;
      --border: #262626;
      --text: #fafafa;
      --text-muted: #a1a1aa;
      --accent: #3b82f6;
      --green: #22c55e;
      --red: #ef4444;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 2rem;
    }
    .container { max-width: 1000px; margin: 0 auto; padding: 0 2rem; }
    h1 { font-size: 2rem; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-muted); margin-bottom: 0.5rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .card-label { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 0.5rem; }
    .card-value { font-size: 2rem; font-weight: 700; }
    .card-change { font-size: 0.875rem; margin-top: 0.25rem; }
    .card-change.positive { color: var(--green); }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; margin-top: 1rem; min-width: 600px; }
    th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border); }
    th { color: var(--text-muted); font-weight: 500; font-size: 0.875rem; }
    .loading { text-align: center; padding: 4rem; color: var(--text-muted); }
    .error { color: var(--red); padding: 2rem; text-align: center; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
    .last-updated { color: var(--text-muted); font-size: 0.75rem; display: block; margin-top: 0.5rem; }
    .refresh-btn {
      background: var(--accent);
      color: white;
      border: none;
      padding: 0.6rem 1.2rem;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.875rem;
      font-weight: 500;
      transition: opacity 0.2s;
    }
    .refresh-btn:hover { opacity: 0.9; }
    .refresh-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    h3 { margin-bottom: 0.5rem; }
    @media (max-width: 640px) {
      body { padding: 1rem; }
      .container { padding: 0 0.5rem; }
      .card { padding: 1rem; }
      .card-value { font-size: 1.5rem; }
      h1 { font-size: 1.5rem; }
      .grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div>
        <h1>📊 Blog Analytics</h1>
        <p class="subtitle">themenonlab.com — Last 7 days</p>
        <span class="last-updated" id="lastUpdated">Loading...</span>
      </div>
      <button class="refresh-btn" id="refreshBtn" onclick="fetchAnalytics()">↻ Refresh</button>
    </div>

    <div id="content">
      <div class="loading">Loading analytics...</div>
    </div>
  </div>

  <script>
    const WORKER_URL = 'https://blog-analytics.prahlad-menon.workers.dev/';

    function formatBytes(bytes) {
      if (bytes >= 1073741824) return (bytes / 1073741824).toFixed(2) + ' GB';
      if (bytes >= 1048576) return (bytes / 1048576).toFixed(1) + ' MB';
      if (bytes >= 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return bytes + ' B';
    }

    function formatNumber(num) {
      return num.toLocaleString();
    }

    function formatDate(dateStr) {
      return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', { 
        weekday: 'short', 
        month: 'short', 
        day: 'numeric' 
      });
    }

    async function fetchAnalytics() {
      const content = document.getElementById('content');
      const btn = document.getElementById('refreshBtn');
      const updated = document.getElementById('lastUpdated');
      
      btn.disabled = true;
      btn.textContent = '↻ Loading...';

      try {
        const response = await fetch(WORKER_URL);
        const result = await response.json();
        
        if (result.errors) {
          throw new Error(result.errors[0].message);
        }

        const days = result.data.viewer.zones[0].httpRequests1dGroups;
        renderAnalytics(days);
        updated.textContent = `Updated: ${new Date().toLocaleString()}`;
      } catch (error) {
        content.innerHTML = `<div class="error">Error: ${error.message}</div>`;
      } finally {
        btn.disabled = false;
        btn.textContent = '↻ Refresh';
      }
    }

    function renderAnalytics(days) {
      const totals = days.reduce((acc, day) => ({
        visitors: acc.visitors + day.uniq.uniques,
        pageViews: acc.pageViews + day.sum.pageViews,
        requests: acc.requests + day.sum.requests,
        bandwidth: acc.bandwidth + day.sum.bytes,
        threats: acc.threats + day.sum.threats
      }), { visitors: 0, pageViews: 0, requests: 0, bandwidth: 0, threats: 0 });

      const avgVisitors = Math.round(totals.visitors / days.length);
      const avgPageViews = Math.round(totals.pageViews / days.length);

      document.getElementById('content').innerHTML = `
        <div class="grid">
          <div class="card">
            <div class="card-label">Total Visitors</div>
            <div class="card-value">${formatNumber(totals.visitors)}</div>
            <div class="card-change">${avgVisitors}/day avg</div>
          </div>
          <div class="card">
            <div class="card-label">Page Views</div>
            <div class="card-value">${formatNumber(totals.pageViews)}</div>
            <div class="card-change">${avgPageViews}/day avg</div>
          </div>
          <div class="card">
            <div class="card-label">Bandwidth</div>
            <div class="card-value">${formatBytes(totals.bandwidth)}</div>
          </div>
          <div class="card">
            <div class="card-label">Threats Blocked</div>
            <div class="card-value">${formatNumber(totals.threats)}</div>
            <div class="card-change positive">🛡️ Protected</div>
          </div>
        </div>

        <div class="card">
          <h3>Daily Breakdown</h3>
          <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Visitors</th>
                <th>Page Views</th>
                <th>Requests</th>
                <th>Bandwidth</th>
                <th>Threats</th>
              </tr>
            </thead>
            <tbody>
              ${days.map(day => `
                <tr>
                  <td>${formatDate(day.dimensions.date)}</td>
                  <td>${formatNumber(day.uniq.uniques)}</td>
                  <td>${formatNumber(day.sum.pageViews)}</td>
                  <td>${formatNumber(day.sum.requests)}</td>
                  <td>${formatBytes(day.sum.bytes)}</td>
                  <td>${day.sum.threats}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
          </div>
        </div>
      `;
    }

    // Load on page load
    fetchAnalytics();
  </script>
</body>
</html>
